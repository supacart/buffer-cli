{
  "name": "@supacart/buffer-cli",
  "version": "0.1.3",
  "description": "Unofficial CLI for drafting and publishing Buffer posts.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supacart/buffer-cli.git"
  },
  "homepage": "https://github.com/supacart/buffer-cli#readme",
  "bugs": {
    "url": "https://github.com/supacart/buffer-cli/issues"
  },
  "keywords": [
    "buffer",
    "cli",
    "social-media",
    "facebook",
    "scheduler"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "buffer": "dist/index.js"
  },
  "scripts": {
    "buffer": "node ./src/index.ts",
    "build": "pnpm exec tsc -p tsconfig.json",
    "social": "node ./src/index.ts",
    "check": "pnpm build",
    "prepublishOnly": "pnpm check"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
